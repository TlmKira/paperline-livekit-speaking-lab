<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for hardened runtime with JIT (V8 in Electron) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Required to allow unsigned executable memory (Electron internals) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Allow the bundled Python runtime to load local native extensions from Cadence's venv -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Allow outbound network connections (Supabase, Stripe, AI APIs) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Allow microphone access for pronunciation recording -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
  </dict>
</plist>
